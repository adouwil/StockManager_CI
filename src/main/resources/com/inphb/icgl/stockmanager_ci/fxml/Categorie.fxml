<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<SplitPane dividerPositions="0.65" styleClass="page-split" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.inphb.icgl.stockmanager_ci.controller.CategorieController">

    <!-- ── Gauche : TableView + pagination ─────────────────────────── -->
    <VBox spacing="10" styleClass="page-content">
        <Label fx:id="lblCategorie" styleClass="page-title" text="  Catégories" />

        <HBox alignment="CENTER_LEFT" spacing="8">
            <TextField fx:id="txtRecherche" prefWidth="280" promptText="🔍 Rechercher par libellé…" styleClass="search-field" />
        </HBox>

        <TableView fx:id="tableCat" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" prefWidth="73.33331310749054" text="ID" />
                <TableColumn fx:id="colLibelle" prefWidth="225.33334350585938" text="Libellé" />
                <TableColumn fx:id="colDescription" prefWidth="389.3333435058594" text="Description" />
            </columns>
            <placeholder><Label text="Aucune catégorie enregistrée" /></placeholder>
        </TableView>

        <!-- Pagination -->
        <HBox alignment="CENTER_LEFT" spacing="8" styleClass="pag-bar">
            <Button fx:id="btnPrecedent" onAction="#handlePrecedent" styleClass="btn-pag" text="‹ Préc." />
            <Label fx:id="lblPage" styleClass="pag-label" text="Page 1 / 1" />
            <Button fx:id="btnSuivant" onAction="#handleSuivant" styleClass="btn-pag" text="Suiv. ›" />
        </HBox>
    </VBox>

    <!-- Droite : Formulaire  -->
    <VBox spacing="14" styleClass="form-panel">
        <Label styleClass="form-title" text="Formulaire catégorie" />

        <VBox spacing="5">
            <Label styleClass="form-label" text="Libellé *" />
            <TextField fx:id="txtLibelle" promptText="Ex : Alimentaire" styleClass="form-field" />
        </VBox>
        <VBox spacing="5">
            <Label styleClass="form-label" text="Description" />
            <TextArea fx:id="txtDescription" prefRowCount="3" promptText="Description optionnelle" styleClass="form-area" />
        </VBox>

        <Label fx:id="lblStatut" styleClass="lbl-statut" text="" wrapText="true" />

        <HBox spacing="8">
            <Button fx:id="btnSauvegarder" maxWidth="1.7976931348623157E308" onAction="#handleSauvegarder" prefHeight="25.0" prefWidth="159.0" styleClass="btn-primary" text="Ajouter" HBox.hgrow="ALWAYS" />
            <Button onAction="#handleAnnuler" prefHeight="25.0" prefWidth="98.0" styleClass="btn-secondary" text="Annuler" />
           <Button maxWidth="Infinity" onAction="#handleSupprimer" prefHeight="25.0" prefWidth="129.0" styleClass="btn-danger" text="Supprimer" />
        </HBox>
    </VBox>

</SplitPane>
